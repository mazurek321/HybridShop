{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-openapi-route": {
        "ClusterId": "auth-cluster",
        "Order": 1,
        "Match": {
          "Path": "/api/auth/openapi/{**catch-all}"
        }
      },
      "products-openapi-route": {
        "ClusterId": "products-cluster",
        "Order": 2,
        "Match": {
          "Path": "/api/products/openapi/{**catch-all}"
        }
      },
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Order": 3,
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "Order": 4,
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "Order": 5,
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "products-route": {
        "ClusterId": "products-cluster",
        "Order": 6,
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://auth-service:8080"
          }
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://notification-service:8080"
          }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://order-service:8080"
          }
        }
      },
      "products-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://product-service:8080"
          }
        }
      }
    }
  }
}